# ====================================
# 微信公众号配置（必填）
# ====================================
# 从微信公众平台获取: https://mp.weixin.qq.com/
# 路径: 设置与开发 → 基本配置
WECHAT_APP_ID=your_app_id_here
WECHAT_APP_SECRET=your_app_secret_here

# ====================================
# 运行模式配置（可选）
# ====================================
# 设置为 true 强制自动模式（用于定时任务）
WECHAT_AUTO_MODE=false

# ====================================
# 内容验证配置（可选）
# ====================================
# 用于内容搜索和事实验证
# 安装: pip install tavily-python
# 获取: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here